<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<installer-gui-script minSpecVersion="1">
    <title>@CPACK_PACKAGE_NAME@</title>
    <welcome file="@CPACK_RESOURCE_FILE_WELCOME_NOPATH@"/>
    <readme file="@CPACK_RESOURCE_FILE_README_NOPATH@"/>
    <license file="@CPACK_RESOURCE_FILE_LICENSE_NOPATH@"/>
    <options allow-external-scripts="no" customize="always" rootVolumeOnly="false"/>
    <choices-outline>
        <line choice="pluginChoice"/>
        <line choice="LegacyQuickTimeCleanupChoice"/>
    </choices-outline>
    <choice id="pluginChoice" title="@CPACK_COMPONENT_PLUGIN_DISPLAY_NAME@" start_selected="true" start_enabled="false" start_visible="true" description="@CPACK_COMPONENT_PLUGIN_DESCRIPTION@">
        <pkg-ref id="com.@CPACK_PACKAGE_VENDOR@.@CPACK_PACKAGE_NAME@.plugin"/>
    </choice>
    <choice id="LegacyQuickTimeCleanupChoice" title="@CPACK_COMPONENT_LEGACYQUICKTIMECLEANUP_DISPLAY_NAME@" start_selected="true" start_enabled="true" start_visible="true" description="@CPACK_COMPONENT_LEGACYQUICKTIMECLEANUP_DESCRIPTION@">
        <pkg-ref id="com.@CPACK_PACKAGE_VENDOR@.@CPACK_PACKAGE_NAME@.LegacyQuickTimeCleanup"/>
    </choice>
    <pkg-ref id="com.@CPACK_PACKAGE_VENDOR@.@CPACK_PACKAGE_NAME@.plugin" version="@CPACK_PACKAGE_VERSION@" installKBytes="0" auth="Admin" onConclusion="None" updateKBytes="0">#@CPACK_PACKAGE_FILE_NAME@-plugin.pkg</pkg-ref>
    <pkg-ref id="com.@CPACK_PACKAGE_VENDOR@.@CPACK_PACKAGE_NAME@.LegacyQuickTimeCleanup" version="@CPACK_PACKAGE_VERSION@" installKBytes="0" auth="Admin" onConclusion="None" updateKBytes="0">#@CPACK_PACKAGE_FILE_NAME@-LegacyQuickTimeCleanup.pkg</pkg-ref>
    <pkg-ref id="com.@CPACK_PACKAGE_VENDOR@.@CPACK_PACKAGE_NAME@.plugin">
        <bundle-version>
            <bundle CFBundleShortVersionString="" CFBundleVersion="" id="org.hapcommunity.HapCodecPlugin.aex" path="Library/Application Support/Adobe/Common/Plug-ins/7.0/MediaCore/HAPAfterEffectsPlugin.bundle"/>
            <bundle CFBundleShortVersionString="" CFBundleVersion="" id="org.hapcommunity.HapCodecPlugin.pr" path="Library/Application Support/Adobe/Common/Plug-ins/7.0/MediaCore/HAPPremierePlugin.bundle"/>
        </bundle-version>
    </pkg-ref>
    <pkg-ref id="com.@CPACK_PACKAGE_VENDOR@.@CPACK_PACKAGE_NAME@.LegacyQuickTimeCleanup">
        <bundle-version/>
    </pkg-ref>
    <product version="@CPACK_PACKAGE_VERSION@"/>
</installer-gui-script>
